rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - balance: number (required)
    //   - role: string (required, 'user' or 'admin')
    //   - isBlocked: boolean
    //   - photoURL: string
    //
    // Collection: investments
    // Document ID: {investmentId}
    // Fields:
    //   - uid: string (required)
    //   - planName: string (required)
    //   - amount: number (required)
    //   - dailyProfit: number (required)
    //   - daysLeft: number (required)
    //   - totalDays: number (required)
    //   - status: string (required, 'active' or 'completed')
    //   - lastProfitUpdate: timestamp
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - uid: string (required)
    //   - type: string (required, 'deposit' or 'withdraw')
    //   - amount: number (required)
    //   - status: string (required, 'pending', 'approved', 'rejected')
    //   - method: string
    //   - createdAt: timestamp (required)
    // Collection: support_chats
    // Document ID: {chatId}
    // Fields:
    //   - uid: string (required)
    //   - senderId: string (required)
    //   - senderName: string
    //   - text: string (required)
    //   - createdAt: timestamp (required)
    //   - isAdmin: boolean (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "chenwave9@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.balance is number &&
             data.role in ['user', 'admin'];
    }

    function isValidInvestment(data) {
      return data.uid is string &&
             data.planName is string &&
             data.amount is number &&
             data.dailyProfit is number &&
             data.daysLeft is number &&
             data.totalDays is number &&
             data.status in ['active', 'completed'];
    }

    function isValidTransaction(data) {
      return data.uid is string &&
             data.type in ['deposit', 'withdraw'] &&
             data.amount is number &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidSupportChat(data) {
      return data.uid is string &&
             data.senderId is string &&
             data.text is string &&
             data.isAdmin is bool;
    }

    // Rules
    match /users/{userId} {
      // Allow any authenticated user to read any user document (needed for referral check)
      // We allow 'get' for individual docs and 'list' for referrals or small limit queries
      allow get: if isAuthenticated();
      allow list: if isAdmin() || (isAuthenticated() && (resource.data.referredBy == request.auth.uid || request.query.limit <= 100));
      
      allow create: if isAuthenticated() && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /investments/{investmentId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin();
    }

    match /support_chats/{chatId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
